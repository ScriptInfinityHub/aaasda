local function GetLevel()
local lv = game:GetService("Players").LocalPlayer.PlayerGui.ScreenGui.HUD.Level.Text
local lv2 = string.match(lv, "%d+")
local Level = tonumber(lv2)

return Level
end

local function CheckQuest()
    local info = {
        monname = "",
    }
    if GetLevel() <= 199 then
        info.monname = "Bandit"
        elseif GetLevel() > 200 and GetLevel() <=399 then
        info.monname = "Monkey"
        elseif GetLevel() > 400 and GetLevel() <=599 then
        info.monname = "Shank"
        elseif GetLevel() > 600 and GetLevel() <=799 then
        info.monname = "Snow Bandit"
        elseif GetLevel() > 800 and GetLevel() <=999 then
        info.monname = "Mihawk"
    end

    return info
end
    
